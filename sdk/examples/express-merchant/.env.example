# Copy to `.env` or `.env.local` (both gitignored) — never commit real keys.
#
# ── Stripe Test Mode (recommended for board sandbox / npm run sandbox) ──
# Dashboard → Developers → API keys → ensure "Test mode" is ON → Secret key (sk_test_…)
# STRIPE_SECRET_KEY=sk_test_YOUR_TEST_SECRET_FROM_DASHBOARD
# Optional: Developers → Webhooks → add endpoint → signing secret
# STRIPE_WEBHOOK_SECRET=whsec_...
#
# ── In-memory mock PSP (offline dev only) ──
# Omit STRIPE_SECRET_KEY entirely, then use `npm start` (not `npm run sandbox`).
# Mock mode is NOT real Stripe sandbox behavior — use sk_test_ for manual verification.

PORT=3340
# DPP_MOCK_STRIPE_MODE=requires_action
# DPP_AUDIT_LOG=1
