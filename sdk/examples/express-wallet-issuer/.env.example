PORT=3350
DPP_ISSUER=https://127.0.0.1:3350/issuer
DPP_DEMO_USER_ID=user_demo_01
# Bearer token required for POST /v1/agents (wallet operator provisioning)
DPP_OPERATOR_TOKEN=dev-operator-token
# Set to 0 in production to disable public agent registration HTTP route
DPP_AGENT_REGISTRATION=1
# Set to 1 for headless authorize (redirect with code, no HTML consent)
DPP_DEMO_AUTO_CONSENT=0
