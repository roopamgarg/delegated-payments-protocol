{
  "name": "dpp-openai-actions",
  "version": "0.1.0-alpha.0",
  "description": "ChatGPT Actions HTTP adapter for the DPP reference MCP payment tool — link_wallet, preview, confirm, status.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "dpp-openai-actions": "dist/bin/dpp-openai-actions.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "openapi.yaml",
    "chatgpt-oauth-wiring.json",
    ".env.example",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/bin/dpp-openai-actions.js",
    "test": "npm run build && node --test tests/*.test.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "dpp-mcp-payment-tool": "file:../../mcp-payment-tool",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.21",
    "typescript": "^5.4.5"
  },
  "keywords": [
    "dpp",
    "openai",
    "chatgpt",
    "actions",
    "delegated-payments"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/roopamgarg/delegated-payments-protocol.git",
    "directory": "sdk/platform-adapters/openai-actions"
  }
}
