# DPP MCP payment stack (URLs your wallet + merchant mocks already expose)
DPP_WALLET_BASE_URL=http://127.0.0.1:3350
DPP_MERCHANT_BASE_URL=http://127.0.0.1:3340
DPP_WALLET_ISSUER=http://127.0.0.1:3350/issuer

DPP_OAUTH_CLIENT_ID=REPLACE_ME
DPP_MCP_AGENT_SUB=REPLACE_ME_AGENT_SUBJECT
DPP_VAULT_MASTER_KEY=REPLACE_ME_32_BYTE_OR_LONGER_SECRET

DPP_OAUTH_REDIRECT_URI=http://127.0.0.1:8765/oauth/callback
DPP_OAUTH_CALLBACK_HOST=127.0.0.1
DPP_OAUTH_CALLBACK_PORT=8765

# ChatGPT Actions HTTP adapter — clients must repeat the same vault user id ChatGPT binds to via X-DPP-User-Id / body.
DPP_ACTIONS_PORT=8780
DPP_ACTIONS_PUBLIC_URL=http://127.0.0.1:8780
DPP_ACTIONS_API_KEY=REPLACE_ME_CHATGPT_STORED_SECRET
