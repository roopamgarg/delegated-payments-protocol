{
  "name": "dpp-wallet-sdk",
  "version": "0.1.0-alpha.0",
  "description": "Wallet issuer SDK for Delegated Payments Protocol — capability issuance, OAuth linking, intent FSM, and JWKS discovery.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "schemas",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test tests/*.test.js",
    "prepublishOnly": "npm run test"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "decimal.js": "^10.5.0",
    "jose": "^6.0.11"
  },
  "peerDependencies": {
    "@aws-sdk/client-kms": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/client-kms": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "typescript": "^5.4.5"
  },
  "keywords": [
    "dpp",
    "delegated-payments",
    "wallet",
    "issuer",
    "oauth"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/roopamgarg/delegated-payments-protocol.git",
    "directory": "sdk/wallet-sdk"
  }
}
